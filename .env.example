# Copy this file to `.env` in the repository root and set values locally.
# Do not commit `.env` (it is gitignored).
#
# Metro reads variables that you import from `@env` in JS (react-native-dotenv).
# After changing `.env`, restart Metro with cache clear: `npm start -- --reset-cache`
#
# Gradle / sentry-cli do not read this file automatically. Use `scripts/build-apk-release.sh`
# (it sources `.env`), or `export SENTRY_AUTH_TOKEN=...` before `./gradlew`, or Android Studio env.

# Sentry JavaScript client DSN (ingest URL for events/crashes from the app).
SENTRY_DSN=

# Org auth token for sentry-cli (source maps upload on release builds). Build-time only — never
# import this from `@env` in application code.
SENTRY_AUTH_TOKEN=
